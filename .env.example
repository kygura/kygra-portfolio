# ─── Notion → blog pipeline ────────────────────────────────────────────────

# Notion integration token (Settings → Connections → your integration).
NOTION_SECRET=ntn_xxx

# The data source queried by the v5 API. Prefer setting this explicitly.
# If omitted, it is derived from NOTION_DATABASE_ID at runtime.
NOTION_DATA_SOURCE_ID=

# The Publications database ID (fallback source for the data-source ID).
NOTION_DATABASE_ID=

# HMAC key used to verify the X-Notion-Signature header. Notion sends this once
# during the subscription handshake — POST to /api/notion/webhook captures it in
# the logs; paste the value here.
NOTION_WEBHOOK_VERIFICATION_TOKEN=

# Bearer secret guarding the manual full-sync endpoint (POST /api/notion/sync).
NOTION_SYNC_TRIGGER_SECRET=

# Vercel Blob read/write token (runtime post storage + build-time seeding).
# NOTION_SYNC_READ_WRITE_TOKEN is accepted as a fallback name.
BLOB_READ_WRITE_TOKEN=

# ─── Frontend ──────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
